{
  "info": {
    "name": "Anime List",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "User",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"foo\",\n  \"email\": \"foo@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = JSON.parse(responseBody).data;",
                  "pm.collectionVariables.set(\"accessToken\", data.accessToken);",
                  "pm.collectionVariables.set(\"refreshToken\", data.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account\": \"foo\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/refresh",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Bookshelf",
      "item": [
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bookshelves",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"正在追\"\n}"
            }
          }
        },
        {
          "name": "List",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bookshelves",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        },
        {
          "name": "Get",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/bookshelves/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/bookshelves/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"已看完\"\n}"
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/bookshelves/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        },
        {
          "name": "Add Item",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/bookshelves/1/items",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"animeId\": 1\n}"
            }
          }
        },
        {
          "name": "Remove Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/bookshelves/1/items/1",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ]
          }
        }
      ]
    }
  ]
}
